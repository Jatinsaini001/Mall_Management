# ══════════════════════════════════════════════════════════════
#  .gitignore — MallOS (Flask + MongoDB)
#  NEVER commit any file listed here to GitHub
# ══════════════════════════════════════════════════════════════

# ── Environment & Secrets ─────────────────────────────────────
# Contains your MongoDB URI, SECRET_KEY — keep this PRIVATE
.env
.env.*
.env.local
.env.production

# ── Python Cache ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyc

# ── Virtual Environment ───────────────────────────────────────
venv/
env/
ENV/
.venv/
.virtualenv/

# ── SQLite Database ───────────────────────────────────────────
# users.db contains hashed passwords — don't commit
*.db
*.sqlite3
*.sqlite

# ── Generated QR codes ────────────────────────────────────────
# These are auto-generated at runtime, no need to version them
static/qr/*.png
static/qr/*.svg
# But keep the folder itself
!static/qr/.gitkeep

# ── Flask/Python build artifacts ──────────────────────────────
*.egg-info/
dist/
build/
.eggs/
*.egg
MANIFEST

# ── OS Files ──────────────────────────────────────────────────
.DS_Store           # macOS
Thumbs.db           # Windows
Desktop.ini
ehthumbs.db

# ── Editor & IDE Files ────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/

# ── Pytest / Testing ──────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml

# ── Distribution / Packaging ──────────────────────────────────
*.tar.gz
*.zip

# ── Ngrok ─────────────────────────────────────────────────────
ngrok.exe
ngrok
